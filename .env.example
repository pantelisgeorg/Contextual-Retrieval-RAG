OPENAI_API_KEY=sk-your-openai-api-key-here

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_QUERY_EXPANSION_MODEL=hf.co/tobil/qmd-query-expansion-1.7b-GGUF:Q4_K_M

RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHROMA_DB_PATH=./data/chromadb
SOURCES_DIR=./sources
CHUNK_SIZE=800
CHUNK_OVERLAP=100
QUERY_EXPANSION=false
RERANKING=true
BM25_HYBRID=true
SEMANTIC_WEIGHT=0.8
BM25_WEIGHT=0.2
TOP_K=10
USE_DOCLING=false

# OCR (Docling only). Leave off for born-digital PDFs — they have a real text
# layer and Docling reads it directly. Enable only for scanned docs. Requires
# Tesseract installed system-wide (apt install tesseract-ocr) plus a language
# pack per language (e.g. tesseract-ocr-ell for Greek, tesseract-ocr-eng).
OCR_ENABLED=false
OCR_LANGS=ell+eng

# Docling document model.
#   default     — standard layout pipeline + TableFormer v2. Reads the embedded
#                 text layer (accurate text) and fixes table cell alignment.
#   smoldocling — 256M vision-language model (docling-project/SmolDocling-256M).
#                 Runs in-process via transformers on the GPU (float16). Best for
#                 scanned documents with no text layer; OCRs the page image.
DOCLING_MODEL=default
# SmolDocling only: longest image edge (px) fed to the VLM. Lower uses less VRAM.
DOCLING_VLM_MAX_SIZE=1280

# Answer synthesis — when true, the API/CLI call an LLM with the retrieved
# passages to produce a written answer (cited inline). Set false to get raw
# chunks only (legacy behavior).
ANSWER_SYNTHESIS=true
ANSWER_MODEL=gpt-4o-mini
ANSWER_MAX_TOKENS=800

# Uncomment to force CPU on older GPUs (compute capability < 6.x) where torch's
# pre-built CUDA kernels are incompatible (e.g. Quadro K620).
# CUDA_VISIBLE_DEVICES=
