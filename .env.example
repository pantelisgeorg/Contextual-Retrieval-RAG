OPENAI_API_KEY=sk-your-openai-api-key-here

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_QUERY_EXPANSION_MODEL=qmd-query-expansion

RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHROMA_DB_PATH=./data/chromadb
SOURCES_DIR=./sources
CHUNK_SIZE=800
CHUNK_OVERLAP=100
QUERY_EXPANSION=false
RERANKING=true
BM25_HYBRID=true
SEMANTIC_WEIGHT=0.8
BM25_WEIGHT=0.2
TOP_K=10
USE_DOCLING=false

# Answer synthesis — when true, the API/CLI call an LLM with the retrieved
# passages to produce a written answer (cited inline). Set false to get raw
# chunks only (legacy behavior).
ANSWER_SYNTHESIS=true
ANSWER_MODEL=gpt-4o-mini
ANSWER_MAX_TOKENS=800

# Uncomment to force CPU on older GPUs (compute capability < 6.x) where torch's
# pre-built CUDA kernels are incompatible (e.g. Quadro K620).
# CUDA_VISIBLE_DEVICES=
